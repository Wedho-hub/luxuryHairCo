*~
*.bak
*.orig

# System files
.DS_Store
*.pem
*.key

# Cache folders
.cache
.tmp

# Hidden tool metadata
.sixth/

# Ignore local npm and yarn files
package-lock.json.tmp
yarn.lock.tmp

# IDE workspace metadata
/.history

# Recommended for full-stack web apps
/dist/
/build/
/public/build/

# If you're using Expo, Next.js, Nuxt, Create React App, or similar
/node_modules/
/.expo/
/.next/
/.nuxt/
/.cache/

# Prevent tracking of local debug and runtime state
.env*
.local

